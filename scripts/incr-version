#!/usr/bin/env bash
set -e

VERSION_FILE="version.txt"
if [[ ! -f "$VERSION_FILE" ]]; then
  echo "Error: $VERSION_FILE not found"
  exit 1
fi

CURRENT=$(cat "$VERSION_FILE")
CURRENT=${CURRENT#v}
PARTS=(${CURRENT//./ })

case "${1:-build}" in
  major)
    MAJOR=$((${PARTS[0]:-1} + 1))
    NEW="v${MAJOR}.0.0"
    ;;
  minor)
    MAJOR=${PARTS[0]:-1}
    MINOR=$((${PARTS[1]:-0} + 1))
    NEW="v${MAJOR}.${MINOR}.0"
    ;;
  patch)
    MAJOR=${PARTS[0]:-1}
    MINOR=${PARTS[1]:-0}
    PATCH=$((${PARTS[2]:-0} + 1))
    NEW="v${MAJOR}.${MINOR}.${PATCH}"
    ;;
  build)
    MAJOR=${PARTS[0]:-1}
    MINOR=${PARTS[1]:-0}
    PATCH=${PARTS[2]:-0}
    BUILD=$((${PARTS[3]:-0} + 1))
    NEW="v${MAJOR}.${MINOR}.${PATCH}.${BUILD}"
    ;;
  *)
    echo "Usage: $0 [major|minor|patch|build]"
    exit 1
    ;;
esac

echo "$NEW" > "$VERSION_FILE"
echo "Version: $CURRENT -> $NEW"
